<!--
  소비측 프로젝트의 pom.xml 에 추가할 의존성 예시.
  install-to-m2.bat 으로 4개 (hwpConverter, hwplib, hwpxlib, hwp2hwpx) 를
  로컬 m2 에 설치한 뒤 아래 dependency 를 그대로 사용하세요.

  나머지 의존성(poi, log4j, commons-*, SparseBitSet)은 Maven Central 에
  배포된 정식 버전이므로 그대로 가져옵니다 — 우리가 빌드한 GitHub-소스
  버전은 hwplib/hwpxlib/hwp2hwpx 만이고, POI 등은 Maven Central 의
  같은 버전과 동일합니다.
-->
<dependencies>

    <!-- 자체 변환기 -->
    <dependency>
        <groupId>kr.n.nframe</groupId>
        <artifactId>hwpConverter</artifactId>
        <version>13.15</version>
    </dependency>

    <!-- neolord0 (로컬 m2 에 install-file 로 설치됨) -->
    <dependency>
        <groupId>kr.dogfoot</groupId>
        <artifactId>hwplib</artifactId>
        <version>1.1.10</version>
    </dependency>
    <dependency>
        <groupId>kr.dogfoot</groupId>
        <artifactId>hwpxlib</artifactId>
        <version>1.0.9</version>
    </dependency>
    <dependency>
        <groupId>kr.dogfoot</groupId>
        <artifactId>hwp2hwpx</artifactId>
        <version>1.0.0</version>
    </dependency>

    <!-- Maven Central 에서 자동 해결 -->
    <dependency>
        <groupId>org.apache.poi</groupId>
        <artifactId>poi</artifactId>
        <version>5.2.5</version>
    </dependency>
    <dependency>
        <groupId>org.apache.logging.log4j</groupId>
        <artifactId>log4j-api</artifactId>
        <version>2.22.1</version>
    </dependency>
    <dependency>
        <groupId>org.apache.logging.log4j</groupId>
        <artifactId>log4j-core</artifactId>
        <version>2.22.1</version>
    </dependency>
    <dependency>
        <groupId>commons-codec</groupId>
        <artifactId>commons-codec</artifactId>
        <version>1.16.0</version>
    </dependency>
    <dependency>
        <groupId>commons-collections</groupId>
        <artifactId>commons-collections</artifactId>
        <version>3.2.2</version>
    </dependency>
    <dependency>
        <groupId>commons-io</groupId>
        <artifactId>commons-io</artifactId>
        <version>2.15.1</version>
    </dependency>
    <dependency>
        <groupId>org.apache.commons</groupId>
        <artifactId>commons-math3</artifactId>
        <version>3.6.1</version>
    </dependency>
    <dependency>
        <groupId>com.zaxxer</groupId>
        <artifactId>SparseBitSet</artifactId>
        <version>1.3</version>
    </dependency>

</dependencies>
