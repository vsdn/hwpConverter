# ============================================================
#  Build / IDE 산출물
# ============================================================
/bin/
/out/
/build/
/hwpConverter.jar
/hwpConverter.bat

# ============================================================
#  IDE 메타데이터
# ============================================================
# Eclipse
/.metadata/
/.settings/
/.project
/.classpath
*.launch

# IntelliJ IDEA
/.idea/
*.iml
*.iws
*.ipr

# VS Code
/.vscode/

# ============================================================
#  변환 산출물 / 테스트 출력 / 임시 파일
# ============================================================
/output/
/output_*/
/temp/
/temp_*/
*.tmp.hwp
*.rewrite.tmp

# ============================================================
#  리포지토리에 포함하지 않는 폴더
# ============================================================
# 테스트 입력 HWP/HWPX (대용량·저작권 이슈 가능)
/hwp/

# HWP 스펙 PDF 및 참고 자료 (재배포 라이선스 확인 필요)
/Document/

# 배포 템플릿 (레거시, release/ 로 대체됨)
/dist/

# 로컬 릴리스 스테이징 폴더 (사용자별 산출물)
/release/
# 버전별 릴리스 폴더 (release-26.05.1, release-26.06.1 등 — dist/*.zip 만 배포)
/release-*/

# API 사용 예제의 빌드 산출물 (예제 소스/스크립트는 추적)
/apitest/build/
/apitest/out/

# ============================================================
#  JVM 크래시 덤프
# ============================================================
hs_err_pid*.log
replay_pid*.log
*.hprof

# ============================================================
#  아카이브 / 백업
# ============================================================
*.zip
# 모든 백업 변종 (.bak, .bak2, .bak3 등)
*.bak*
*.swp
*~

# ============================================================
#  Claude Code 로컬 설정
#  - settings.json 은 팀 공유 대상이므로 추적 허용
#  - settings.local.json 은 사용자 로컬 전용이므로 제외
# ============================================================
/.claude/settings.local.json
/.claude/*.local.json
# Claude Code 워크트리 (로컬 작업 공간 — 항상 제외)
/.claude/worktrees/

# 프로젝트 외부 가이드 (이 저장소에 동봉하지 않음)
/CLAUDE.md

# ============================================================
#  OS 노이즈
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
