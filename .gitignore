# ============================================================
#  Build / IDE 산출물
# ============================================================
/bin/
/out/
/build/
/hwpConverter.jar

# ============================================================
#  IDE 메타데이터
# ============================================================
# Eclipse
/.metadata/
/.settings/
/.project
/.classpath
*.launch

# IntelliJ IDEA
/.idea/
*.iml
*.iws
*.ipr

# VS Code
/.vscode/

# ============================================================
#  변환 산출물 / 테스트 출력 / 임시 파일
# ============================================================
/output/
/output_*/
/temp/
/temp_*/
*.tmp.hwp
*.rewrite.tmp

# ============================================================
#  리포지토리에 포함하지 않는 폴더
# ============================================================
# 테스트 입력 HWP/HWPX (대용량·저작권 이슈 가능)
/hwp/

# HWP 스펙 PDF 및 참고 자료 (재배포 라이선스 확인 필요)
/Document/

# 배포 템플릿 (레거시, release/ 로 대체됨)
/dist/

# 로컬 릴리스 스테이징 폴더 (사용자별 산출물)
/release/

# ============================================================
#  JVM 크래시 덤프
# ============================================================
hs_err_pid*.log
replay_pid*.log
*.hprof

# ============================================================
#  아카이브 / 백업
# ============================================================
*.zip
*.bak
*.swp
*~

# ============================================================
#  Claude Code 로컬 설정
#  - settings.json 은 팀 공유 대상이므로 추적 허용
#  - settings.local.json 은 사용자 로컬 전용이므로 제외
# ============================================================
/.claude/settings.local.json
/.claude/*.local.json

# ============================================================
#  OS 노이즈
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
